# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# No trailing slashes. Example:
#   ALLOWED_ORIGINS=https://app.jurident.com,https://staging.jurident.com
ALLOWED_ORIGINS=http://localhost:3000

# ─── HMAC (server-to-server only) ─────────────────────────────────────────────
# Generate a value with: node scripts/generate-secrets.js
# Only apply verifyHmac middleware to trusted server-to-server routes.
HMAC_SECRET=d078da05250a31b0c24248f0a9d3588e869854eaba22abd3372e1676d86fe6e55f7557e6807416c0c00020dcdb6ae787588abfcbfc93b2f631670e49dcaebe35

# ─── Firebase Admin SDK (GCP) ─────────────────────────────────────────────────
# On GCP (Cloud Run, GKE, App Engine) — leave blank.
#   Firebase Admin uses Application Default Credentials automatically.
#
# For local development:
#   1. Download service-account.json from GCP Console → IAM → Service Accounts
#   2. Point this variable at that file:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Firebase Client SDK (frontend reference — NOT used by this server) ───────
# These are only here so you can copy them to the frontend .env.
# The backend does NOT import these — it uses ADC (above).
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Render single-service gateway + backend
INTERNAL_BACKEND_PORT=3000
INTERNAL_SERVICE_URL=http://127.0.0.1:3000
GATEWAY_PORT=4000
INTERNAL_HMAC_SECRET=
